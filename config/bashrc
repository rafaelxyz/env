o-cpp-checks() {
    cppcheck --enable=all --inconclusive --std=posix . 2> cppcheck.txt
    cpplint * 2> cpplint.txt
}

o-color-print() {
    # for use in tmux
    for i in {0..255} ; do
        printf "\x1b[38;5;${i}mcolour${i}\n"
    done
}
