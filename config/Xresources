xterm*faceName: DejaVuSansMono Nerd Font:Regular:size=11:antialias=false
!xterm*faceName: DejaVu Sans Mono:normal:size=10,5:antialias=false

xterm*savelines: 16384
xterm*scrollBar: off
xterm*rightScrollBar: true
xterm*ScrollBar: true
xterm*scrollTtyOutput: false
xterm*toolBar: off
! Do not include whitespaces when selecting text
xterm*trimSelection: true

! double-click to select whole URLs
!xterm*charClass: 33:48,36-47:48,58-59:48,61:48,63-64:48,95:48,126:48
xterm*charClass: 33:48,36-47:48,59:48,61:48,63-64:48,95:48,126:48

! paste from CLIPBOARD
! copy to CLIPBOARD as well as default PRIMARY
 xterm.VT100.Translations:    #override \n\
         Shift <KeyPress> Insert:        insert-selection(CLIPBOARD) \n\
         <Btn1Up>: select-end(PRIMARY, CLIPBOARD, CUT_BUFFER0)

!Colors
*.foreground: #BCBCBC
*.background: #262626
